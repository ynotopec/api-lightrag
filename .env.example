############################
# Server
############################

HOST=0.0.0.0
PORT=9621
WEBUI_TITLE='LightRAG'
WEBUI_DESCRIPTION='Graph RAG Server'

# WORKERS=1
# TIMEOUT=300
# LOG_LEVEL=INFO
# VERBOSE=False

INPUT_DIR=./inputs
WORKING_DIR=./rag_storage
# Si true, run.sh recrée automatiquement l'index local si la config embedding change.
# Désactive (false) si tu veux gérer manuellement les migrations d'index.
AUTO_RESET_ON_EMBEDDING_CHANGE=true

############################
# API token
############################

# Recommandé : mets un token long.
# Utilisation API : header HTTP X-API-Key.
LIGHTRAG_API_KEY=change-me-super-long-token

# Par défaut LightRAG exclut certains chemins.
# Pour sécuriser davantage, évite /api/* si tu n’as pas besoin de l’émulation Ollama publique.
WHITELIST_PATHS=/health

############################
# Web UI auth / JWT
############################

# Fortement conseillé si exposition réseau.
# Générer bcrypt :
#   source ~/venv/lightrag/bin/activate
#   lightrag-hash-password --username admin
# AUTH_ACCOUNTS='admin:{bcrypt}$2b$12$replace-with-generated-hash'
# TOKEN_SECRET=change-me-super-long-jwt-secret
# TOKEN_EXPIRE_HOURS=48

############################
# RAG defaults
############################

SUMMARY_LANGUAGE=French

CHUNK_SIZE=1200
CHUNK_OVERLAP_SIZE=100

MAX_ASYNC=4
MAX_PARALLEL_INSERT=2
EMBEDDING_FUNC_MAX_ASYNC=8
EMBEDDING_BATCH_NUM=10

TOP_K=40
CHUNK_TOP_K=20
MAX_ENTITY_TOKENS=6000
MAX_RELATION_TOKENS=8000
MAX_TOTAL_TOKENS=30000

ENABLE_LLM_CACHE=true
ENABLE_LLM_CACHE_FOR_EXTRACT=true

############################
# LLM - OpenAI-compatible
############################

LLM_BINDING=openai
LLM_BINDING_HOST=http://127.0.0.1:4000/v1
LLM_BINDING_API_KEY=sk-local
LLM_MODEL=qwen3.5:35b

# Pour Qwen via vLLM/SGLang si besoin de désactiver le thinking :
# OPENAI_LLM_EXTRA_BODY='{"chat_template_kwargs":{"enable_thinking":false}}'

# OPENAI_LLM_TEMPERATURE=0.3
# OPENAI_LLM_MAX_TOKENS=9000
# LLM_TIMEOUT=300

############################
# Embedding - OpenAI-compatible
############################

EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=http://127.0.0.1:4001/v1
EMBEDDING_BINDING_API_KEY=sk-local
EMBEDDING_MODEL=BAAI/bge-m3
# Optionnel: laisse vide pour simplifier, LightRAG détectera la dimension via le modèle/backend.
# EMBEDDING_DIM=1024
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_SEND_DIM=false

# Profil alternatif (multilingue premium, beaucoup plus lourd) :
# EMBEDDING_MODEL=BAAI/bge-multilingual-gemma2
# EMBEDDING_DIM=3584  # optionnel ; utile surtout en override/validation stricte
# EMBEDDING_TOKEN_LIMIT=8192
# IMPORTANT: si tu changes la dimension d'embedding sur un index existant,
# purge `rag_storage/*` (ou change `WORKING_DIR`) avant redémarrage.

############################
# Ollama alternative
############################

# LLM_BINDING=ollama
# LLM_BINDING_HOST=http://127.0.0.1:11434
# LLM_MODEL=qwen3.5:35b
# OLLAMA_LLM_NUM_CTX=32768

# EMBEDDING_BINDING=ollama
# EMBEDDING_BINDING_HOST=http://127.0.0.1:11434
# EMBEDDING_MODEL=bge-m3:latest
# EMBEDDING_DIM=1024
# OLLAMA_EMBEDDING_NUM_CTX=8192

############################
# Reranker optional
############################

RERANK_BINDING=null
# Note: pas de variable RERANK_MAX_ASYNC dans ce template.
# Le parallélisme rerank suit surtout MAX_ASYNC (concurrence globale requêtes).

# RERANK_BINDING=cohere
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_BINDING_HOST=http://127.0.0.1:8000/rerank
# RERANK_BINDING_API_KEY=sk-local
# MIN_RERANK_SCORE=0.0
# RERANK_BY_DEFAULT=True

############################
# Storage simple
############################

LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage

############################
# Storage production optional
############################

# LIGHTRAG_KV_STORAGE=RedisKVStorage
# LIGHTRAG_DOC_STATUS_STORAGE=RedisDocStatusStorage
# LIGHTRAG_VECTOR_STORAGE=QdrantVectorDBStorage
# LIGHTRAG_GRAPH_STORAGE=MemgraphStorage

# REDIS_URI=redis://localhost:6379
# QDRANT_URL=http://localhost:6333
# MEMGRAPH_URI=bolt://localhost:7687
# MEMGRAPH_USERNAME=
# MEMGRAPH_PASSWORD=
